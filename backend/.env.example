# --- Base de datos (Postgres + pgvector) ---
DATABASE_URL=postgres://postgres:postgres@localhost:5432/memorias_vivas

# --- Redis / BullMQ ---
REDIS_URL=redis://localhost:6379

# --- Almacenamiento (MinIO en local / Cloudflare R2 o S3 en producción) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=auto
S3_BUCKET=memorias-vivas-media
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
# URL pública desde la que se sirven los ficheros (dominio público de R2/CDN
# en producción; en local puede apuntar al propio MinIO)
S3_PUBLIC_BASE_URL=http://localhost:9000/memorias-vivas-media

# --- Clerk (autenticación) ---
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx

# --- IA (reconocimiento facial, embeddings, remasterizado) ---
REPLICATE_API_TOKEN=r8_xxxxxxxxxxxxxxxxxxxxxxxx
HUGGINGFACE_API_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxx

# --- App ---
PORT=3000
NODE_ENV=development
